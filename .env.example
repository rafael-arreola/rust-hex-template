# Puerto del servidor Axum HTTP
PORT=3000

# Nombre del servicio
SERVICE_NAME=rust-hex-template

# Entorno de la aplicación (LCL, SBX, PRD)
APP_ENV=LCL

# Identificador del proyecto de GCP (para tracing/telemetría opcional)
PROJECT_ID=local-gcp-project

# URL de conexión a MongoDB
MONGO_URL=mongodb://localhost:27017

# Nombre de la base de datos de MongoDB
MONGO_DB=service_db

# Nivel de depuración de logs (trace, debug, info, warn, error)
DEBUG_LEVEL=info

# Orígenes CORS permitidos (separados por comas, o * para todos)
CORS_ORIGINS=*

# Tiempo de drenado de conexiones en vuelo al recibir SIGTERM (segundos)
DRAIN_TIMEOUT_SECS=10

# Negociación de contenido MessagePack (Accept: application/vnd.msgpack)
# Activo por defecto; solo codifica msgpack cuando el cliente lo solicita
ENABLE_MSGPACK=true
